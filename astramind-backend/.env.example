# ──────────────────────────────────────────────────────────────────────────────
# Astramind — .env.example
# Copy to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Configuration ──────────────────────────────────────────────────────────
# Switch: development (Ollama, local) | production (Groq, cloud)
AI_ENV=development

# Ollama (local dev) — install at https://ollama.com | model: ollama pull deepseek-coder:6.7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b

# Groq (production) — free key at https://console.groq.com (no credit card)
GROQ_API_KEY=get_free_key_at_console_groq_com
GROQ_MODEL=llama-3.1-70b-versatile

# ── Database Configuration ────────────────────────────────────────────────────
# Switch: development (SQLite, local file) | production (Supabase Postgres, cloud)
DB_ENV=development

# SQLite (dev) — no setup needed, file auto-created
DATABASE_URL=sqlite+aiosqlite:///./astramind.db

# Supabase (prod) — free 500MB Postgres at https://supabase.com (no credit card)
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Vector Store ──────────────────────────────────────────────────────────────
# ChromaDB (dev) — runs in-process, zero setup
CHROMADB_PATH=./chromadb_data

# Qdrant Cloud (prod) — free 1GB cluster at https://cloud.qdrant.io (no credit card)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_free_qdrant_key

# ── Cache ─────────────────────────────────────────────────────────────────────
# In-memory dict (dev) — no setup needed
# Upstash Redis (prod) — free 10k cmd/day at https://upstash.com (no credit card)
REDIS_URL=rediss://:your_password@your-host.upstash.io:6380

# ── Application ───────────────────────────────────────────────────────────────
REPOS_STORAGE_PATH=./repos
MAX_FILE_SIZE_KB=500
ALLOWED_ORIGINS=http://localhost:3000
PORT=8000
